<div id="container-info-element">
  <!--
    This for loop follows iterates through all the elements in the elements array and creates a div
    for each element and the information about it. The non-display class is added to all divs except
    for the one representing hydrogen (atomic number 1).
  -->
  <%
    for( let el of elements ) {
  %>
  <div class="info-element <%= el.atomicNumber != 1 ? "non-display" : "" %>" id="<%= el.elementSymbol %>-info">
    <div class="info-element-box">
      <div class="info-element-box-atomic-number"><%= el.atomicNumber %> </div>
      <div class="info-element-box-symbol"><%= el.elementSymbol %> </div>
    </div>
    <div class="info-element-text">
      <h2 class="info-element-text-heading"> <%= el.lementName %> </h2>
      <div> <strong>Atomic mass:</strong> <%= el.atomicMass %> g/mol</div>
      <div> <strong>Classification:</strong> <%= el.classification %> </div>
      <div> <strong>Density:</strong> <%= el.density ? `${el.density} g/cm\u00b3` : "N/A" %> </div>
      <div> <strong>Melting point:</strong> <%= el.meltingPoint ? `${el.meltingPoint} K` : "N/A" %> </div>
      <div> <strong>Boiling point:</strong> <%= el.boilingPoint ? `${el.boilingPoint} K` : "N/A" %> </div>
    </div>
  </div>
  <% } %>
</div>